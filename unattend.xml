<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <!-- Set PC name -->
      <ComputerName>MyDesktopPC</ComputerName>

      <!-- Create local user -->
      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>DesktopUser</Name>
            <Group>Administrators</Group>
            <Password>
              <Value>MySecurePassword123</Value>
              <PlainText>true</PlainText>
            </Password>
            <DisplayName>Desktop User</DisplayName>
            <Description>Main desktop user account</Description>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <!-- Auto logon -->
      <AutoLogon>
        <Password>
          <Value>MySecurePassword123</Value>
          <PlainText>true</PlainText>
        </Password>
        <Enabled>true</Enabled>
        <Username>DesktopUser</Username>
      </AutoLogon>

      <!-- Optional desktop personalization -->
      <TimeZone>Pacific Standard Time</TimeZone>
      <Wallpaper>%WINDIR%\Web\Wallpaper\Windows\img0.jpg</Wallpaper>

    </component>
  </settings>
</unattend>
